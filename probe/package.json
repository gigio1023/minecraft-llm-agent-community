{
  "name": "headless-mineflayer-probe",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "test": "ACTOR_WORKSPACE_INIT=1 bun test",
    "typecheck": "tsc --noEmit",
    "probe:v0": "bun run src/cli.ts",
    "probe:live": "bun run src/cli.ts --provider openai-codex --npcs 3 --observe-ms 120000",
    "probe:v1": "bun run src/mutual/cli.ts",
    "probe:v1:live": "bun run src/mutual/liveCli.ts",
    "probe:village:skills": "bun run src/mutual/skillVillageCli.ts",
    "server:ready": "bun run src/server/liveSmokeCli.ts ready",
    "server:status": "bun run src/server/liveSmokeCli.ts status",
    "server:stop": "bun run src/server/liveSmokeCli.ts stop",
    "dashboard": "bun run src/dashboard/dashboardServer.ts",
    "review:actors": "bun run src/reviewer/cli.ts",
    "archive:legacy-skills": "bun run src/skills/legacy/archiveCli.ts"
  },
  "dependencies": {
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "elysia": "^1.4.28",
    "minecraft-data": "^3.110.2",
    "minecraft-protocol": "^1.66.2",
    "mineflayer": "^4.37.1",
    "mineflayer-pathfinder": "^2.4.5",
    "prismarine-item": "^1.18.0",
    "vec3": "^0.2.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3"
  }
}
