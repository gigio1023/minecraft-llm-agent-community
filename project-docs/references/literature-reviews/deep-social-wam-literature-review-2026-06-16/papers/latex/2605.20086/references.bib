}

@misc{wiedemann2026,
  title = {{{KernelFoundry}}: {{Hardware-aware}} Evolutionary {{GPU}} Kernel Optimization},
  shorttitle = {{{KernelFoundry}}},
  author = {Wiedemann, Nina and Leboutet, Quentin and Paulitsch, Michael and Wofk, Diana and Ummenhofer, Benjamin},
