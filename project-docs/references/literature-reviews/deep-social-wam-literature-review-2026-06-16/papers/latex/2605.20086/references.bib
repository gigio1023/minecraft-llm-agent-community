@misc{song2025,
  title = {Iterated {{Agent}} for {{Symbolic Regression}}},
  author = {Song, Zhuo-Yang and Cai, Zeyu and Zhang, Shutao and Wei, Jiashen and Pan, Jichen and Qiu, Shi and Cao, Qing-Hong and Hou, Tie-Jiun and Liu, Xiaohui and Luo, Ming-xing and Zhu, Hua Xing},
