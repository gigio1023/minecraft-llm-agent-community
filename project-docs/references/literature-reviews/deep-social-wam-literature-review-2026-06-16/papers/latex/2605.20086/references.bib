@misc{ye2026,
  title = {Meta {{Context Engineering}} via {{Agentic Skill Evolution}}},
  author = {Ye, Haoran and He, Xuning and Arak, Vincent and Dong, Haonan and Song, Guojie},
  year = 2026,
  month = feb,
  number = {arXiv:2601.21557},
  eprint = {2601.21557},
