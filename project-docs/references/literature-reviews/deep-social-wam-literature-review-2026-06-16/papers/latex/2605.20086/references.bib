@misc{chen2026b,
  title = {{{CausalEvolve}}: {{Towards Open-Ended Discovery}} with {{Causal Scratchpad}}},
  shorttitle = {{{CausalEvolve}}},
  author = {Chen, Yongqiang and Liu, Chenxi and Chen, Zhenhao and Liu, Tongliang and Han, Bo and Zhang, Kun},
  year = 2026,
