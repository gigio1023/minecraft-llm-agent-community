  note = {\url{https://arxiv.org/abs/2603.24647}},
}

@misc{friedman2023,
  title = {The {{Vendi Score}}: {{A Diversity Evaluation Metric}} for {{Machine Learning}}},
  shorttitle = {The {{Vendi Score}}},
  author = {Friedman, Dan and Dieng, Adji Bousso},
  year = 2023,
  month = jul,
  number = {arXiv:2210.02410},
