@misc{leleu2026,
  title = {Contrastive {{Concept-Tree Search}} for {{LLM-Assisted Algorithm Discovery}}},
  author = {Leleu, Timothee and Gunathilaka, Sudeera and Ghimenti, Federico and Ganguli, Surya},
  year = 2026,
