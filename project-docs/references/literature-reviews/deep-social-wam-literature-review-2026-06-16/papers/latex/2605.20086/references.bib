@misc{yan2026,
  title = {{{PACEvolve}}: {{Enabling Long-Horizon Progress-Aware Consistent Evolution}}},
  shorttitle = {{{PACEvolve}}},
  author = {Yan, Minghao and Peng, Bo and Coleman, Benjamin and Chen, Ziqi and Xie, Zhouhang and Chen, Shuo and He, Zhankui and Sachdeva, Noveen and Ye, Isabella and Wang, Weili and Wang, Chi and Chi, Ed H. and Pereira, Fernando and Kang, Wang-Cheng and Cheng, Derek Zhiyuan and Wang, Beidou},
  year = 2026,
