  keywords = {Computer Science - Computation and Language,Computer Science - Machine Learning},
  file = {/Users/npelleriti/Zotero/storage/3B8XEDWH/Lange et al. - 2025 - ShinkaEvolve Towards Open-Ended And Sample-Efficient Program Evolution.pdf;/Users/npelleriti/Zotero/storage/BR6D46TH/2509.html},
