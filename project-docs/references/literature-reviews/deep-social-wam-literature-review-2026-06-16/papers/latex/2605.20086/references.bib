@misc{xie2025b,
  title = {How {{Far Are AI Scientists}} from {{Changing}} the {{World}}?},
  author = {Xie, Qiujie and Weng, Yixuan and Zhu, Minjun and Shen, Fuchen and Huang, Shulin and Lin, Zhen and Zhou, Jiahui and Mao, Zilan and Yang, Zijie and Yang, Linyi and Wu, Jian and Zhang, Yue},
