  note = {\url{https://arxiv.org/abs/2603.02787}},
}

@misc{zhang2026d,
  title = {What {{Makes}} an {{LLM}} a {{Good Optimizer}}? {{A Trajectory Analysis}} of {{LLM-Guided Evolutionary Search}}},
  shorttitle = {What {{Makes}} an {{LLM}} a {{Good Optimizer}}?},
  author = {Zhang, Xinhao and Chen, Xi and Portet, Fran{\c c}ois and Peyrard, Maxime},
