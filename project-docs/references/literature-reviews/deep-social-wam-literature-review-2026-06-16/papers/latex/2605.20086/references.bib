@misc{li2025c,
  title = {C-{{Evolve}}: {{Consensus-based Evolution}} for {{Prompt Groups}}},
  shorttitle = {C-{{Evolve}}},
  author = {Li, Tiancheng and Wang, Yuhang and Chen, Zhiyang and Wang, Zijun and Ma, Liyuan and Qi, Guo-jun},
