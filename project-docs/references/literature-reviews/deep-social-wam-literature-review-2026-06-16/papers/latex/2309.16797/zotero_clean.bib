}

@misc{deng2023mind2web,
  title = {{{Mind2Web}}: {{Towards}} a {{Generalist Agent}} for the {{Web}}},
  shorttitle = {{{Mind2Web}}},
  author = {Deng, Xiang and Gu, Yu and Zheng, Boyuan and Chen, Shijie and Stevens, Samuel and Wang, Boshi and Sun, Huan and Su, Yu},
  year = {2023},
