@misc{gandhi2023understanding,
  title = {Understanding {{Social Reasoning}} in {{Language Models}} with {{Language Models}}},
  author = {Gandhi, Kanishk and Fr{\"a}nken, Jan-Philipp and Gerstenberg, Tobias and Goodman, Noah D.},
  year = {2023},
