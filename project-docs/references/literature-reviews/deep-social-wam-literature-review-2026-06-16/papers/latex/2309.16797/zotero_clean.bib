@misc{cao2023hexplane,
  title = {{{HexPlane}}: {{A Fast Representation}} for {{Dynamic Scenes}}},
  shorttitle = {{{HexPlane}}},
  author = {Cao, Ang and Johnson, Justin},
  year = {2023},
