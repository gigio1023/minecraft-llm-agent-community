  keywords = {Computer Science - Computer Vision and Pattern Recognition},
  file = {/Users/rocktaschel/Documents/Zettelkasten/Papers/pdf/chang2022maskgit.pdf;/Users/rocktaschel/Zotero/storage/9VWXPU7R/2202.html}
