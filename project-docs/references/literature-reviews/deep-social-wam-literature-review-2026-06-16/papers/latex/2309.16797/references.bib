@misc{piterbarg2023nethack,
  title = {{{NetHack}} Is {{Hard}} to {{Hack}}},
  author = {Piterbarg, Ulyana and Pinto, Lerrel and Fergus, Rob},
  year = {2023},
  month = may,
  number = {arXiv:2305.19240},
