  author = {Mandlekar, Ajay and Xu, Danfei and Wong, Josiah and Nasiriany, Soroush and Wang, Chen and Kulkarni, Rohun and {Fei-Fei}, Li and Savarese, Silvio and Zhu, Yuke and {Mart{\'i}n-Mart{\'i}n}, Roberto},
  year = {2021},
