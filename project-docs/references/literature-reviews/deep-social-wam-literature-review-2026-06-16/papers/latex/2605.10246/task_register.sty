% task_register_readable.sty
% Helper style for wrapped JSON/code blocks in the task information register.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{task_register_readable}[2026/04/30 wrapped code blocks for task register]
\RequirePackage{xcolor}
\RequirePackage{fvextra}
\DefineVerbatimEnvironment{JsonBlock}{Verbatim}{%
  fontsize=\scriptsize,
  breaklines=true,
  breakanywhere=true,
  breakautoindent=true,
  tabsize=2,
  frame=single,
  framesep=2mm,
  framerule=0.2pt
}
\setlength{\emergencystretch}{2em}
