\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c+c1}{\PYGZsh{} Get scores}
\PYG{n}{cal\PYGZus{}scores} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{maximum}\PYG{p}{(}\PYG{n}{cal\PYGZus{}labels}\PYG{o}{\PYGZhy{}}\PYG{n}{model\PYGZus{}upper}\PYG{p}{(}\PYG{n}{cal\PYGZus{}X}\PYG{p}{),} \PYG{n}{model\PYGZus{}lower}\PYG{p}{(}\PYG{n}{cal\PYGZus{}X}\PYG{p}{)}\PYG{o}{\PYGZhy{}}\PYG{n}{cal\PYGZus{}labels}\PYG{p}{)}
\PYG{c+c1}{\PYGZsh{} Get the score quantile}
\PYG{n}{qhat} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{quantile}\PYG{p}{(}\PYG{n}{cal\PYGZus{}scores}\PYG{p}{,} \PYG{n}{np}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{((}\PYG{n}{n}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{o}{*}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{o}{\PYGZhy{}}\PYG{n}{alpha}\PYG{p}{))}\PYG{o}{/}\PYG{n}{n}\PYG{p}{,} \PYG{n}{interpolation}\PYG{o}{=}\PYG{l+s+s1}{\PYGZsq{}higher\PYGZsq{}}\PYG{p}{)}
\PYG{c+c1}{\PYGZsh{} Deploy (output=lower and upper adjusted quantiles)}
\PYG{n}{prediction\PYGZus{}sets} \PYG{o}{=} \PYG{p}{[}\PYG{n}{val\PYGZus{}lower} \PYG{o}{\PYGZhy{}} \PYG{n}{qhat}\PYG{p}{,} \PYG{n}{val\PYGZus{}upper} \PYG{o}{+} \PYG{n}{qhat}\PYG{p}{]}
\end{Verbatim}
