\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c+c1}{\PYGZsh{} model(X)[:,0]=E(Y|X), and model(X)[:,1]=stddev(Y|X)}
\PYG{n}{scores} \PYG{o}{=} \PYG{n+nb}{abs}\PYG{p}{(}\PYG{n}{model}\PYG{p}{(}\PYG{n}{calib\PYGZus{}X}\PYG{p}{)[:,}\PYG{l+m+mi}{0}\PYG{p}{]}\PYG{o}{\PYGZhy{}}\PYG{n}{calib\PYGZus{}Y}\PYG{p}{)}\PYG{o}{/}\PYG{n}{model}\PYG{p}{(}\PYG{n}{calib\PYGZus{}X}\PYG{p}{)[:,}\PYG{l+m+mi}{1}\PYG{p}{]}
\PYG{c+c1}{\PYGZsh{} Get the score quantile}
\PYG{n}{qhat} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{quantile}\PYG{p}{(}\PYG{n}{scores}\PYG{p}{,}\PYG{n}{np}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{((}\PYG{n}{n}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{o}{*}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{o}{\PYGZhy{}}\PYG{n}{alpha}\PYG{p}{))}\PYG{o}{/}\PYG{n}{n}\PYG{p}{)}
\PYG{c+c1}{\PYGZsh{} Deploy (represent sets as tuple of lower and upper endpoints)}
\PYG{n}{muhat}\PYG{p}{,} \PYG{n}{stdhat} \PYG{o}{=} \PYG{p}{(}\PYG{n}{model}\PYG{p}{(}\PYG{n}{test\PYGZus{}X}\PYG{p}{)[:,}\PYG{l+m+mi}{0}\PYG{p}{],} \PYG{n}{model}\PYG{p}{(}\PYG{n}{test\PYGZus{}X}\PYG{p}{)[:,}\PYG{l+m+mi}{1}\PYG{p}{])}
\PYG{n}{prediction\PYGZus{}sets} \PYG{o}{=} \PYG{p}{(}\PYG{n}{muhat}\PYG{o}{\PYGZhy{}}\PYG{n}{stdhat}\PYG{o}{*}\PYG{n}{qhat}\PYG{p}{,} \PYG{n}{muhat}\PYG{o}{+}\PYG{n}{stdhat}\PYG{o}{*}\PYG{n}{qhat}\PYG{p}{)}
\end{Verbatim}
