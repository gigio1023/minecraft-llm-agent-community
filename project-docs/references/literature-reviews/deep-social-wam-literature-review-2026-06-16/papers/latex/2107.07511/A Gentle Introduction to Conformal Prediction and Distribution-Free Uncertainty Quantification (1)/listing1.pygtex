\PYG{c+c1}{\PYGZsh{} 2: get adjusted quantile}
\PYG{n}{q\PYGZus{}level} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{ceil}\PYG{p}{((}\PYG{n}{n}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{o}{*}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{o}{\PYGZhy{}}\PYG{n}{alpha}\PYG{p}{))}\PYG{o}{/}\PYG{n}{n}
