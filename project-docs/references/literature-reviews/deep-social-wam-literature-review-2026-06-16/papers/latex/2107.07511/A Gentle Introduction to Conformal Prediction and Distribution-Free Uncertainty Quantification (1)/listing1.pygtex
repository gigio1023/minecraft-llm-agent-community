\PYG{c+c1}{\PYGZsh{} 1: get conformal scores. n = calib\PYGZus{}Y.shape[0]}
\PYG{n}{cal\PYGZus{}smx} \PYG{o}{=} \PYG{n}{model}\PYG{p}{(}\PYG{n}{calib\PYGZus{}X}\PYG{p}{)}\PYG{o}{.}\PYG{n}{softmax}\PYG{p}{(}\PYG{n}{dim}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{o}{.}\PYG{n}{numpy}\PYG{p}{()}
