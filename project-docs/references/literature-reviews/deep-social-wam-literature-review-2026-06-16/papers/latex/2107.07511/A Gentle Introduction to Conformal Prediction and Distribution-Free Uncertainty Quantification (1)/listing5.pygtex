  \PYG{n}{calib\PYGZus{}scores}\PYG{p}{,} \PYG{n}{val\PYGZus{}scores} \PYG{o}{=} \PYG{p}{(}\PYG{n}{scores}\PYG{p}{[:}\PYG{n}{n}\PYG{p}{],}\PYG{n}{scores}\PYG{p}{[}\PYG{n}{n}\PYG{p}{:])} \PYG{c+c1}{\PYGZsh{} split}
