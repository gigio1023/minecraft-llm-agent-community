\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c+c1}{\PYGZsh{} Implementation of LTT. Assume access to X, Y where n=X.shape[0]=Y.shape[0]}
\PYG{n}{lambdas} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{linspace}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{,}\PYG{l+m+mi}{1}\PYG{p}{,}\PYG{n}{N}\PYG{p}{)} \PYG{c+c1}{\PYGZsh{} Commonly choose N=1000}
\PYG{n}{losses} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{((}\PYG{n}{n}\PYG{p}{,}\PYG{n}{N}\PYG{p}{))} \PYG{c+c1}{\PYGZsh{} Compute the loss function next}
\PYG{k}{for} \PYG{p}{(}\PYG{n}{i}\PYG{p}{,}\PYG{n}{j}\PYG{p}{)} \PYG{o+ow}{in} \PYG{p}{[(}\PYG{n}{i}\PYG{p}{,}\PYG{n}{j}\PYG{p}{)} \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{n}\PYG{p}{)} \PYG{k}{for} \PYG{n}{j} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{N}\PYG{p}{)]:}
  \PYG{n}{prediction\PYGZus{}set} \PYG{o}{=} \PYG{n}{T}\PYG{p}{(}\PYG{n}{X}\PYG{p}{[}\PYG{n}{i}\PYG{p}{],}\PYG{n}{lambdas}\PYG{p}{[}\PYG{n}{j}\PYG{p}{])} \PYG{c+c1}{\PYGZsh{} T ( ) is problem depemdent}
  \PYG{n}{losses}\PYG{p}{[}\PYG{n}{i}\PYG{p}{,}\PYG{n}{j}\PYG{p}{]} \PYG{o}{=} \PYG{n}{get\PYGZus{}loss}\PYG{p}{(}\PYG{n}{prediction\PYGZus{}set}\PYG{p}{,}\PYG{n}{Y}\PYG{p}{[}\PYG{n}{i}\PYG{p}{])} \PYG{c+c1}{\PYGZsh{} Loss is problem dependent}
\PYG{n}{risk} \PYG{o}{=} \PYG{n}{losses}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{n}{dim}\PYG{o}{=}\PYG{l+m+mi}{0}\PYG{p}{)}
\PYG{n}{pvals} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{exp}\PYG{p}{(}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{2}\PYG{o}{*}\PYG{n}{n}\PYG{o}{*}\PYG{p}{(}\PYG{n}{torch}\PYG{o}{.}\PYG{n}{relu}\PYG{p}{(}\PYG{n}{alpha}\PYG{o}{\PYGZhy{}}\PYG{n}{risk}\PYG{p}{)}\PYG{o}{**}\PYG{l+m+mi}{2}\PYG{p}{))} \PYG{c+c1}{\PYGZsh{} Or any p\PYGZhy{}value}
\PYG{n}{lambda\PYGZus{}hat} \PYG{o}{=} \PYG{n}{lambdas}\PYG{p}{[}\PYG{n}{pvals}\PYG{o}{\PYGZlt{}}\PYG{n}{delta}\PYG{o}{/}\PYG{n}{lambdas}\PYG{o}{.}\PYG{n}{shape}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]]} \PYG{c+c1}{\PYGZsh{} Or any FWER\PYGZhy{}controlling algorithm}
\end{Verbatim}
