\begin{Verbatim}[commandchars=\\\{\}]
\PYG{k}{def} \PYG{n+nf}{sum\PYGZus{}ascii\PYGZus{}values}\PYG{p}{(}\PYG{n}{string}\PYG{p}{):}
    \PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    This function takes a string}
\PYG{l+s+sd}{    as input and returns the}
\PYG{l+s+sd}{    sum of ASCII values of all}
\PYG{l+s+sd}{    uppercase letters in the string.}
\PYG{l+s+sd}{    Parameters:}
\PYG{l+s+sd}{    string (str): The input string.}
\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{    int: The sum of ASCII values of}
\PYG{l+s+sd}{    uppercase letters in the string.}
\PYG{l+s+sd}{    Example:}
\PYG{l+s+sd}{    \PYGZgt{}\PYGZgt{}\PYGZgt{} sum\PYGZus{}ascii\PYGZus{}values(\PYGZsq{}Hello}
\PYG{l+s+sd}{        World\PYGZsq{})}
\PYG{l+s+sd}{    628}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{c+c1}{\PYGZsh{} Initialize sum to 0}
    \PYG{n}{ascii\PYGZus{}sum} \PYG{o}{=} \PYG{l+m+mi}{0}
    \PYG{c+c1}{\PYGZsh{} Iterate through each}
    \PYG{c+c1}{\PYGZsh{} character in the input string}
    \PYG{k}{for} \PYG{n}{char} \PYG{o+ow}{in} \PYG{n}{string}\PYG{p}{:}
        \PYG{c+c1}{\PYGZsh{} Check if the character}
        \PYG{c+c1}{\PYGZsh{} is an uppercase letter}
        \PYG{k}{if} \PYG{n}{char}\PYG{o}{.}\PYG{n}{isupper}\PYG{p}{():}
            \PYG{c+c1}{\PYGZsh{} Add the ASCII value}
            \PYG{c+c1}{\PYGZsh{} of the uppercase}
            \PYG{c+c1}{\PYGZsh{} letter to the sum}
            \PYG{n}{ascii\PYGZus{}sum} \PYG{o}{+=} \PYG{n+nb}{ord}\PYG{p}{(}\PYG{n}{char}\PYG{p}{)}
    \PYG{k}{return} \PYG{n}{ascii\PYGZus{}sum}
\end{Verbatim}
