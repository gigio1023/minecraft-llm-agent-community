\begin{Verbatim}[commandchars=\\\{\}]
\PYG{k}{def} \PYG{n+nf}{is\PYGZus{}happy}\PYG{p}{(}\PYG{n}{s}\PYG{p}{):}
    \PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}You are given a string s.}
\PYG{l+s+sd}{    Your task is to check if the}
\PYG{l+s+sd}{    string is happy or not. A}
\PYG{l+s+sd}{    string is happy if its length}
\PYG{l+s+sd}{    is at least 3 and every 3}
\PYG{l+s+sd}{    consecutive letters are distinct}
\PYG{l+s+sd}{    For example:}
\PYG{l+s+sd}{    is\PYGZus{}happy(a) =\PYGZgt{} False}
\PYG{l+s+sd}{    is\PYGZus{}happy(aa) =\PYGZgt{} False}
\PYG{l+s+sd}{    is\PYGZus{}happy(abcd) =\PYGZgt{} True}
\PYG{l+s+sd}{    is\PYGZus{}happy(aabb) =\PYGZgt{} False}
\PYG{l+s+sd}{    is\PYGZus{}happy(adb) =\PYGZgt{} True}
\PYG{l+s+sd}{    is\PYGZus{}happy(xyy) =\PYGZgt{} False}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{k}{if} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{s}\PYG{p}{)} \PYG{o}{\PYGZlt{}} \PYG{l+m+mi}{3}\PYG{p}{:}
      \PYG{k}{return} \PYG{k+kc}{False}

    \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{s}\PYG{p}{)} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{2}\PYG{p}{):}

      \PYG{k}{if} \PYG{n}{s}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]} \PYG{o}{==} \PYG{n}{s}\PYG{p}{[}\PYG{n}{i}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{]}
        \PYG{o+ow}{or} \PYG{n}{s}\PYG{p}{[}\PYG{n}{i}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{==} \PYG{n}{s}\PYG{p}{[}\PYG{n}{i}\PYG{o}{+}\PYG{l+m+mi}{2}\PYG{p}{]}
        \PYG{o+ow}{or} \PYG{n}{s}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]} \PYG{o}{==} \PYG{n}{s}\PYG{p}{[}\PYG{n}{i}\PYG{o}{+}\PYG{l+m+mi}{2}\PYG{p}{]:}
        \PYG{k}{return} \PYG{k+kc}{False}
    \PYG{k}{return} \PYG{k+kc}{True}
\end{Verbatim}
