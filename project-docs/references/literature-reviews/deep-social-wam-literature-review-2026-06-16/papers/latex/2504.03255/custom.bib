@misc{he_redteaming_2025,
	title = {Red-{Teaming} {LLM} {Multi}-{Agent} {Systems} via {Communication} {Attacks}},
	url = {http://arxiv.org/abs/2502.14847},
	doi = {10.48550/arXiv.2502.14847},
	abstract = {Large Language Model-based Multi-Agent Systems (LLM-MAS) have revolutionized complex problem-solving capability by enabling sophisticated agent collaboration through message-based communications. While the communication framework is crucial for agent coordination, it also introduces a critical yet unexplored security vulnerability. In this work, we introduce Agent-in-the-Middle (AiTM), a novel attack that exploits the fundamental communication mechanisms in LLM-MAS by intercepting and manipulating inter-agent messages. Unlike existing attacks that compromise individual agents, AiTM demonstrates how an adversary can compromise entire multi-agent systems by only manipulating the messages passing between agents. To enable the attack under the challenges of limited control and role-restricted communication format, we develop an LLM-powered adversarial agent with a reflection mechanism that generates contextually-aware malicious instructions. Our comprehensive evaluation across various frameworks, communication structures, and real-world applications demonstrates that LLM-MAS is vulnerable to communication-based attacks, highlighting the need for robust security measures in multi-agent systems.},
	urldate = {2025-03-11},
	publisher = {arXiv},
	author = {He, Pengfei and Lin, Yupin and Dong, Shen and Xu, Han and Xing, Yue and Liu, Hui},
	month = feb,
	year = {2025},
	note = {arXiv:2502.14847 [cs]},
	keywords = {Computer Science - Cryptography and Security},
	file = {Snapshot:C\:\\Users\\rpatr\\Zotero\\storage\\AVLVWGRX\\2502.html:text/html},
}


@misc{barbi_preventing_2025,
	title = {Preventing {Rogue} {Agents} {Improves} {Multi}-{Agent} {Collaboration}},
	url = {http://arxiv.org/abs/2502.05986},
	doi = {10.48550/arXiv.2502.05986},
	abstract = {Multi-agent systems, where specialized agents collaborate to solve a shared task hold great potential, from increased modularity to simulating complex environments. However, they also have a major caveat -- a single agent can cause the entire system to fail. Consider a simple game where the knowledge to solve the task is distributed between agents, which share information in a communication channel. At each round, any of the agents can terminate the game and make the final prediction, even if they are uncertain about the outcome of their action. Detection of such rogue agents \${\textbackslash}textit\{before they act\}\$ may prevent the system's failure. In this work, we propose to \${\textbackslash}textit\{monitor\}\$ agents during action prediction and \${\textbackslash}textit\{intervene\}\$ when a future error is likely to occur. To test our approach, we introduce WhoDunitEnv, a multi-agent collaboration environment that allows modular control over task complexity and communication structure. Experiments on two variants of WhoDunitEnv and the GovSim environment for resource sustainability show that our approach leads to substantial performance gains up to 17.4\% and 20\%, respectively. Moreover, a thorough analysis shows that our monitors successfully identify critical points of agent confusion and our interventions effectively stop agent errors from propagating.},
	urldate = {2025-03-14},
	publisher = {arXiv},
	author = {Barbi, Ohav and Yoran, Ori and Geva, Mor},
	month = feb,
	year = {2025},
	note = {arXiv:2502.05986 [cs]},
	keywords = {Computer Science - Computation and Language, Computer Science - Multiagent Systems},
	file = {Snapshot:C\:\\Users\\rpatr\\Zotero\\storage\\B4MZSAS2\\2502.html:text/html},
}


@misc{peigne-lefebvre_mas_2025,
	title = {Multi-{Agent} {Security} {Tax}: {Trading} {Off} {Security} and {Collaboration} {Capabilities} in {Multi}-{Agent} {Systems}},
	shorttitle = {Multi-{Agent} {Security} {Tax}},
	url = {http://arxiv.org/abs/2502.19145},
	doi = {10.48550/arXiv.2502.19145},
	abstract = {As AI agents are increasingly adopted to collaborate on complex objectives, ensuring the security of autonomous multi-agent systems becomes crucial. We develop simulations of agents collaborating on shared objectives to study these security risks and security trade-offs. We focus on scenarios where an attacker compromises one agent, using it to steer the entire system toward misaligned outcomes by corrupting other agents. In this context, we observe infectious malicious prompts - the multi-hop spreading of malicious instructions. To mitigate this risk, we evaluated several strategies: two "vaccination" approaches that insert false memories of safely handling malicious input into the agents' memory stream, and two versions of a generic safety instruction strategy. While these defenses reduce the spread and fulfillment of malicious instructions in our experiments, they tend to decrease collaboration capability in the agent network. Our findings illustrate potential trade-off between security and collaborative efficiency in multi-agent systems, providing insights for designing more secure yet effective AI collaborations.},
	urldate = {2025-03-11},
	publisher = {arXiv},
	author = {Peigne-Lefebvre, Pierre and Kniejski, Mikolaj and Sondej, Filip and David, Matthieu and Hoelscher-Obermaier, Jason and Witt, Christian Schroeder de and Kran, Esben},
	month = feb,
	year = {2025},
	note = {arXiv:2502.19145 [cs]},
	keywords = {Computer Science - Artificial Intelligence, Computer Science - Multiagent Systems},
	annote = {Comment: Accepted to AAAI 2025 Conference},
	file = {Snapshot:C\:\\Users\\rpatr\\Zotero\\storage\\Y34KTZ2M\\2502.html:text/html},
}


