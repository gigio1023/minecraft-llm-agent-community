\begin{Verbatim}[commandchars=\\\{\},codes={\catcode`\$=3\catcode`\^=7\catcode`\_=8\relax}]
\PYG{k}{def} \PYG{n+nf}{sort\PYGZus{}array}\PYG{p}{(}\PYG{n}{array}\PYG{p}{):}
    \PYG{k}{def} \PYG{n+nf}{quick\PYGZus{}sort}\PYG{p}{(}\PYG{n}{array}\PYG{p}{,} \PYG{n}{low}\PYG{p}{,} \PYG{n}{high}\PYG{p}{):}
        \PYG{c+c1}{\PYGZsh{} base condition}
        \PYG{k}{if} \PYG{n}{low} \PYG{o}{\PYGZlt{}} \PYG{n}{high}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} find pivot element such that }
            \PYG{c+c1}{\PYGZsh{} element smaller than pivot are on the left}
            \PYG{c+c1}{\PYGZsh{} element greater than pivot are on the right}
            \PYG{n}{pi} \PYG{o}{=} \PYG{n}{partition}\PYG{p}{(}\PYG{n}{array}\PYG{p}{,} \PYG{n}{low}\PYG{p}{,} \PYG{n}{high}\PYG{p}{)}

            \PYG{c+c1}{\PYGZsh{} recursive call on the left of pivot}
            \PYG{n}{quick\PYGZus{}sort}\PYG{p}{(}\PYG{n}{array}\PYG{p}{,} \PYG{n}{low}\PYG{p}{,} \PYG{n}{pi} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1}\PYG{p}{)}

            \PYG{c+c1}{\PYGZsh{} recursive call on the right of pivot}
            \PYG{n}{quick\PYGZus{}sort}\PYG{p}{(}\PYG{n}{array}\PYG{p}{,} \PYG{n}{pi} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{high}\PYG{p}{)}

    \PYG{k}{def} \PYG{n+nf}{partition}\PYG{p}{(}\PYG{n}{array}\PYG{p}{,} \PYG{n}{low}\PYG{p}{,} \PYG{n}{high}\PYG{p}{):}
        \PYG{c+c1}{\PYGZsh{} choose the rightmost element as pivot}
        \PYG{n}{pivot} \PYG{o}{=} \PYG{n}{array}\PYG{p}{[}\PYG{n}{high}\PYG{p}{]}

        \PYG{c+c1}{\PYGZsh{} pointer for the greater element}
        \PYG{n}{i} \PYG{o}{=} \PYG{n}{low} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1}

        \PYG{c+c1}{\PYGZsh{} traverse through all elements}
        \PYG{k}{for} \PYG{n}{j} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{low}\PYG{p}{,} \PYG{n}{high}\PYG{p}{):}
            \PYG{k}{if} \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]} \PYG{o}{\PYGZlt{}=} \PYG{n}{pivot}\PYG{p}{:}
                \PYG{c+c1}{\PYGZsh{} swap element at i with element at j}
                \PYG{n}{i} \PYG{o}{+=} \PYG{l+m+mi}{1}
                \PYG{n}{array}\PYG{p}{[}\PYG{n}{i}\PYG{p}{],} \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]} \PYG{o}{=} \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{p}{],} \PYG{n}{array}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]}

        \PYG{c+c1}{\PYGZsh{} swap pivot element with the greater element specified by i}
        \PYG{n}{array}\PYG{p}{[}\PYG{n}{i} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{],} \PYG{n}{array}\PYG{p}{[}\PYG{n}{high}\PYG{p}{]} \PYG{o}{=} \PYG{n}{array}\PYG{p}{[}\PYG{n}{high}\PYG{p}{],} \PYG{n}{array}\PYG{p}{[}\PYG{n}{i} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{]}

        \PYG{c+c1}{\PYGZsh{} return the position of pivot}
        \PYG{k}{return} \PYG{n}{i} \PYG{o}{+} \PYG{l+m+mi}{1}

    \PYG{k}{if} \PYG{o+ow}{not} \PYG{n}{array}\PYG{p}{:}
        \PYG{k}{return} \PYG{p}{[]}

    \PYG{n}{array\PYGZus{}sorted} \PYG{o}{=} \PYG{n}{array}\PYG{o}{.}\PYG{n}{copy}\PYG{p}{()}

    \PYG{c+c1}{\PYGZsh{} implement quick sort}
    \PYG{n}{quick\PYGZus{}sort}\PYG{p}{(}\PYG{n}{array\PYGZus{}sorted}\PYG{p}{,} \PYG{l+m+mi}{0}\PYG{p}{,} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array\PYGZus{}sorted}\PYG{p}{)} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} check if the sum of the first and last element is odd or even}
    \PYG{k}{if} \PYG{p}{(}\PYG{n}{array}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]} \PYG{o}{+} \PYG{n}{array}\PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{])} \PYG{o}{\PYGZpc{}} \PYG{l+m+mi}{2} \PYG{o}{==} \PYG{l+m+mi}{0}\PYG{p}{:}
        \PYG{k}{return} \PYG{n}{array\PYGZus{}sorted}\PYG{p}{[::}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{]}
    \PYG{k}{else}\PYG{p}{:}
        \PYG{k}{return} \PYG{n}{array\PYGZus{}sorted}
\end{Verbatim}
