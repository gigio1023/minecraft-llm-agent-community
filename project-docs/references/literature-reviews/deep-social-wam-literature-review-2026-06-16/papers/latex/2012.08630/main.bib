@Article{fearon-rationalist,
  author    = {James D. Fearon},
  journal   = {International Organization},
  title     = {Rationalist Explanations for War},
  year      = {1995},
  issn      = {00208183, 15315088},
  number    = {3},
  pages     = {379--414},
  volume    = {49},
  abstract  = {Realist and other scholars commonly hold that rationally led states can and sometimes do fight when no peaceful bargains exist that both would prefer to war. Against this view, I show that under very broad conditions there will exist negotiated settlements that genuinely rational states would mutually prefer to a risky and costly fight. Popular rationalist and realist explanations for war fail either to address or to explain adequately what would prevent leaders from locating a less costly bargain. Essentially just two mechanisms can resolve this puzzle on strictly rationalist terms. The first turns on the fact that states have both private information about capabilities and resolve and the incentive to misrepresent it. The second turns on the fact that in specific strategic contexts states may be unable credibly to commit to uphold a mutually preferable bargain. Historical examples suggest that both mechanisms are empirically plausible.},
  doi       = {10.1017/S0020818300033324},
  publisher = {[MIT Press, University of Wisconsin Press, Cambridge University Press, International Organization Foundation]},
}




@article{10.2307/27871271,
 ISSN = {00028282},
doi={10.1257/aer.100.4.1695},
abstract = {We study costless pre-play communication of intentions among inexperienced players. Using the level-k model of strategic thinking to describe players' beliefs, we fully characterize the effects of preplay communication in symmetric 2x2 games. One-way communication weakly increases coordination on Nash equilibrium outcomes, although average payoffs sometimes decrease. Two-way communication further improves payoffs in some games but is detrimental in others. Moving beyond the class of symmetric 2x2 games, we find that communication facilitates coordination in common interest games with positive spillovers and strategic complementarities, but there are also games in which any type of communication hampers coordination.},
 author = {Tore Ellingsen and Robert \"{O}stling},
 journal = {The American Economic Review},
 number = {4},
 pages = {1695--1724},
 publisher = {American Economic Association},
 title = {When Does Communication Improve Coordination?},
 volume = {100},
 year = {2010}
}


@Article{FARRELL1988209,
