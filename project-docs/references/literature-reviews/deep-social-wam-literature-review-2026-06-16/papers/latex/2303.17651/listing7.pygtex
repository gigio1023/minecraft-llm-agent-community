\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c+c1}{\PYGZsh{} Slower code}
\PYG{k}{def} \PYG{n+nf}{solve}\PYG{p}{(}\PYG{n}{amount}\PYG{p}{):}
  \PYG{n}{best\PYGZus{}price} \PYG{o}{=} \PYG{p}{(}\PYG{n}{amount} \PYG{o}{+} \PYG{l+m+mi}{199}\PYG{p}{)} \PYG{o}{//} \PYG{l+m+mi}{200} \PYG{o}{*} \PYG{l+m+mi}{380}
  \PYG{c+c1}{\PYGZsh{} First loop}
  \PYG{k}{for} \PYG{n}{a} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{amount} \PYG{o}{//} \PYG{l+m+mi}{200} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{):}
    \PYG{c+c1}{\PYGZsh{} ... 4 nested loops ...}
    \PYG{k}{for} \PYG{n}{c1} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{amount} \PYG{o}{//} \PYG{l+m+mi}{1500} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{):}
      \PYG{k}{if} \PYG{n}{a}\PYG{o}{*}\PYG{l+m+mi}{200} \PYG{o}{+} \PYG{n}{b}\PYG{o}{*}\PYG{l+m+mi}{300} \PYG{o}{==} \PYG{n}{amount}\PYG{p}{:}
        \PYG{n}{price} \PYG{o}{=} \PYG{n}{a}\PYG{o}{*}\PYG{l+m+mi}{380} \PYG{o}{+} \PYG{n}{b}\PYG{o}{*}\PYG{l+m+mi}{550}
        \PYG{k}{if} \PYG{n}{price} \PYG{o}{\PYGZlt{}} \PYG{n}{best\PYGZus{}price}\PYG{p}{:}
          \PYG{n}{best\PYGZus{}price} \PYG{o}{=} \PYG{n}{price}
  \PYG{k}{return} \PYG{n}{best\PYGZus{}price}
\end{Verbatim}
