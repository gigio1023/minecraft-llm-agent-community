\begin{Verbatim}[commandchars=\\\{\}]
\PYG{k}{def} \PYG{n+nf}{solution}\PYG{p}{():}
    \PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Twenty dozen cups cost \PYGZdl{}1200 less than the total cost of}
\PYG{l+s+sd}{    half a dozen plates sold at \PYGZdl{}6000 each.}
\PYG{l+s+sd}{    Calculate the total cost of buying each cup.\PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{plates} \PYG{o}{=} \PYG{l+m+mi}{6}
    \PYG{n}{plate\PYGZus{}cost} \PYG{o}{=} \PYG{l+m+mi}{6000}
    \PYG{n}{cups} \PYG{o}{=} \PYG{l+m+mi}{12} \PYG{o}{*} \PYG{l+m+mi}{20}
    \PYG{n}{cup\PYGZus{}cost} \PYG{o}{=} \PYG{n}{plate\PYGZus{}cost}
    \PYG{n}{result} \PYG{o}{=} \PYG{n}{cup\PYGZus{}cost}
    \PYG{k}{return} \PYG{n}{result}
\end{Verbatim}
