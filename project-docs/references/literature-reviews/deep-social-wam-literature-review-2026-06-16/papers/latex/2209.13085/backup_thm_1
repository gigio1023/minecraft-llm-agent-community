\begin{theorem} \label{thm:open-set} % TODO: informal
In any $MDP \setminus \mathcal{R}$, if $\hat{\Pi}$ contains an open set, then any pair of reward functions that are ungameable and non-trivial on $\hat{\Pi}$ are equivalent on $\hat{\Pi}$.
\end{theorem}
\begin{proof}

% Let $R'_1$ and $R'_2$ be arbitrary ungameable and non-trivial reward functions, and define normalized versions $R_1 = \frac{R'_1}{||R'_1||_2}$ and $R_2 = \frac{R'_2}{||R'_2||_2}$.  
% Note that $R_1$ is equivalent to $R'_1$, and $R_2$ is equivalent to $R'_2$.
Let $\mathcal{R}_1$ and $\mathcal{R}_2$ be any two ungameable and non-trivial reward functions.
We will show that, for any $\pi, \pi' \in \hat{\Pi}$, we have $J_1(\pi) = J_1(\pi') \implies J_2(\pi) = J_2(\pi')$, and thus, by symmetry, $J_1(\pi) = J_1(\pi') \iff J_2(\pi) = J_2(\pi')$.
Since $\mathcal{R}_1$ and $\mathcal{R}_2$ are ungameable, this means they have the exact same policy order, i.e.\ they are equivalent. {\color{red} TODO: fix preceding sentence}

Choose two arbitrary $\pi, \pi' \in \hat{\Pi}$ with $J_1(\pi) = J_1(\pi')$ and let $f \doteq \mathcal{F}(\pi), f' \doteq \mathcal{F}(\pi')$.
The proof has 3 steps:% are as follows:
\begin{enumerate}
    \item We find analogues for $f$ and $f'$, $\tilde{f}$ and $\tilde{f'}$, within the same open ball.
    \item We show that the level sets of $\mathcal{R}_1$ and $\mathcal{R}_2$ at $\tilde{f}$ must be equal to prevent neighbors of $\tilde{f}$ from making $\mathcal{R}_1$ and $\mathcal{R}_2$ gameable.
    \item We use linearity to show that this implies that $J_2(\pi) = J_2(\pi')$.
    %\item Since equivalence is transitive, $R'_1$ and $R'_2$ are also equivalent, completing the proof.
\end{enumerate}
