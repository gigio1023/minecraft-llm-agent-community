% =============================================================================
% agent_framework_details.sty
% Readable appendix formatting for research-agent prompts and protocols.
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{agent_framework_details}[2026/04/30 readable agent framework appendix]

\RequirePackage{xcolor}
\RequirePackage{xurl}
\RequirePackage{enumitem}
\RequirePackage{fvextra}
\RequirePackage[most]{tcolorbox}

\definecolor{AgentPromptBg}{HTML}{F7F7F7}
\definecolor{AgentPromptFrame}{HTML}{D8DDE6}
\definecolor{AgentNoteBg}{HTML}{FBFBFB}

\setlist[itemize]{leftmargin=1.6em, itemsep=0.2em, topsep=0.25em}
\setlist[enumerate]{leftmargin=1.8em, itemsep=0.2em, topsep=0.25em}

\newenvironment{AgentDetails}{%
  \begingroup
  \small
  \sloppy
  \setlength{\emergencystretch}{3em}%
  \setlength{\parskip}{0.35em}%
}{%
  \par\endgroup
}

\newenvironment{PromptBlock}
  {\VerbatimEnvironment\begin{Verbatim}[
    breaklines=true,
    breakanywhere=true,
    fontsize=\footnotesize,
    frame=single,
    framesep=2mm,
    framerule=0.2pt
  ]}
  {\end{Verbatim}}