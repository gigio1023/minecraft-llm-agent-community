@inproceedings{cheung2011starcraft,
  author    = {Cheung, Gifford and Huang, Jeff},
  title     = {Starcraft from the Stands: Understanding the Game Spectator},
  booktitle = {Proceedings of the SIGCHI Conference on Human Factors in Computing Systems},
  series    = {CHI '11},
  year      = {2011},
  isbn      = {978-1-4503-0228-9},
  location  = {Vancouver, BC, Canada},
  pages     = {763--772},
  numpages  = {10},
  publisher = {Association for Computing Machinery},
  address   = {New York, NY, USA},
  doi       = {10.1145/1978942.1979053},
  url       = {https://doi.org/10.1145/1978942.1979053},
  keywords  = {spectators, starcraft, video games},
  abstract  = {Video games are primarily designed for the players. However, video game 
               spectating is also a popular activity, boosted by the rise of online video 
               sites and major gaming tournaments. In this paper, we focus on the spectator, 
               who is emerging as an important stakeholder in video games. Our study focuses 
               on Starcraft, a popular real-time strategy game with millions of spectators 
               and high-level tournament play. We have collected over a hundred stories of 
               the Starcraft spectator from online sources, aiming for as diverse a group as 
               possible. We contribute: (i) nine personas explaining who spectators are and 
               why they spectate; (ii) insights into how stakeholders (commentators, players, 
               crowds, designers) influence the spectator experience; and (iii) a theory of 
               information asymmetry that creates suspense for spectators. One design 
               implication is that, rather than presenting as much information as possible to 
               spectators, stakeholders should control how and when information is revealed.}
}


