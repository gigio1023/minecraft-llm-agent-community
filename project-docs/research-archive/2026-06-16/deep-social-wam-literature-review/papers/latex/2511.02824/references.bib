@article{takemura_connectome_2024,
	title = {A {Connectome} of the {Male} {Drosophila} {Ventral} {Nerve} {Cord}},
	volume = {13},
	url = {https://elifesciences.org/reviewed-preprints/97769},
	doi = {10.7554/eLife.97769.1},
	abstract = {Animal behavior is principally expressed through neural control of muscles. Therefore understanding how the brain controls behavior requires mapping neuronal circuits all the way to motor neurons. We have previously established technology to collect large-volume electron microscopy data sets of neural tissue and fully reconstruct the morphology of the neurons and their chemical synaptic connections throughout the volume. Using these tools we generated a dense wiring diagram, or connectome, for a large portion of the Drosophila central brain. However, in most animals, including the fly, the majority of motor neurons are located outside the brain in a neural center closer to the body, i.e. the mammalian spinal cord or insect ventral nerve cord (VNC). In this paper, we extend our effort to map full neural circuits for behavior by generating a connectome of the VNC of a male fly.},
	language = {en},
	urldate = {2025-10-29},
	journal = {eLife},
	author = {Takemura, Shin-ya and Hayworth, Kenneth J. and Huang, Gary B. and Januszewski, Michal and Lu, Zhiyuan and Marin, Elizabeth C. and Preibisch, Stephan and Xu, C. Shan and Bogovic, John and Champion, Andrew S. and Cheong, Han SJ and Costa, Marta and Eichler, Katharina and Katz, William and Knecht, Christopher and Li, Feng and Morris, Billy J. and Ordish, Christopher and Rivlin, Patricia K. and Schlegel, Philipp and Shinomiya, Kazunori and Stürner, Tomke and Zhao, Ting and Badalamente, Griffin and Bailey, Dennis and Brooks, Paul and Canino, Brandon S. and Clements, Jody and Cook, Michael and Duclos, Octave and Dunne, Christopher R. and Fairbanks, Kelli and Fang, Siqi and Finley-May, Samantha and Francis, Audrey and George, Reed and Gkantia, Marina and Harrington, Kyle and Hopkins, Gary Patrick and Hsu, Joseph and Hubbard, Philip M. and Javier, Alexandre and Kainmueller, Dagmar and Korff, Wyatt and Kovalyak, Julie and Krzemiński, Dominik and Lauchie, Shirley A. and Lohff, Alanna and Maldonado, Charli and Manley, Emily A. and Mooney, Caroline and Neace, Erika and Nichols, Matthew and Ogundeyi, Omotara and Okeoma, Nneoma and Paterson, Tyler and Phillips, Elliott and Phillips, Emily M. and Ribeiro, Caitlin and Ryan, Sean M. and Rymer, Jon Thomson and Scott, Anne K. and Scott, Ashley L. and Shepherd, David and Shinomiya, Aya and Smith, Claire and Smith, Natalie and Suleiman, Alia and Takemura, Satoko and Talebi, Iris and Tamimi, Imaan FM and Trautman, Eric T. and Umayam, Lowell and Walsh, John J. and Yang, Tansy and Rubin, Gerald M. and Scheffer, Louis K. and Funke, Jan and Saalfeld, Stephan and Hess, Harald F. and Plaza, Stephen M. and Card, Gwyneth M. and Jefferis, Gregory SXE and Berg, Stuart},
	month = may,
