\newcommand\Tex{}
\newcommand\PR[2][\Tex]{
\ifthenelse{\equal{#1}{}}{{\mathrm{P}}\left[#2\right]}{\ensuremath{{\mathrm{P}}_{#1}\left[ #2\right]}}}

