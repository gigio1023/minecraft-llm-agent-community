\ifthenelse{\equal{#1}{}}{{\mathrm Var}\left[#2\right]}{\ensuremath{{\mathrm Var}_{#1}\left[ #2\right]}}}

\newcommand\Cov[2][\Tex]{
\ifthenelse{\equal{#1}{}}{{\mathrm Var}\left[#2\right]}{\ensuremath{{\mathrm Cov}_{#1}\left[ #2\right]}}}

