\begin{Verbatim}[commandchars=\\\{\},codes={\catcode`\$=3\catcode`\^=7\catcode`\_=8\relax}]
\PYG{k}{def} \PYG{n+nf}{sort\PYGZus{}array}\PYG{p}{(}\PYG{n}{array}\PYG{p}{):}
    \PYG{k}{if} \PYG{o+ow}{not} \PYG{n}{array}\PYG{p}{:}
        \PYG{k}{return} \PYG{p}{[]}

    \PYG{k}{def} \PYG{n+nf}{custom\PYGZus{}sort}\PYG{p}{(}\PYG{n}{array}\PYG{p}{):}
        \PYG{c+c1}{\PYGZsh{} Implementing bubble sort}
        \PYG{n}{n} \PYG{o}{=} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array}\PYG{p}{)}
        \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{n}\PYG{p}{):}
            \PYG{k}{for} \PYG{n}{j} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{,} \PYG{n}{n}\PYG{o}{\PYGZhy{}}\PYG{n}{i}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{):}
                \PYG{k}{if} \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]} \PYG{o}{\PYGZgt{}} \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{]:}
                    \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{p}{],} \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{=} \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{],} \PYG{n}{array}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]}

    \PYG{c+c1}{\PYGZsh{} Create a copy of the array}
    \PYG{n}{array\PYGZus{}sorted} \PYG{o}{=} \PYG{n}{array}\PYG{o}{.}\PYG{n}{copy}\PYG{p}{()}

    \PYG{c+c1}{\PYGZsh{} Check the sum of the first and last element}
    \PYG{k}{if} \PYG{p}{(}\PYG{n}{array}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]} \PYG{o}{+} \PYG{n}{array}\PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{])} \PYG{o}{\PYGZpc{}} \PYG{l+m+mi}{2} \PYG{o}{==} \PYG{l+m+mi}{0}\PYG{p}{:}
        \PYG{n}{custom\PYGZus{}sort}\PYG{p}{(}\PYG{n}{array\PYGZus{}sorted}\PYG{p}{)}
        \PYG{k}{return} \PYG{n}{array\PYGZus{}sorted}\PYG{p}{[::}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{]}  \PYG{c+c1}{\PYGZsh{} Reverse for descending order}
    \PYG{k}{else}\PYG{p}{:}
        \PYG{n}{custom\PYGZus{}sort}\PYG{p}{(}\PYG{n}{array\PYGZus{}sorted}\PYG{p}{)}
        \PYG{k}{return} \PYG{n}{array\PYGZus{}sorted}
\end{Verbatim}
