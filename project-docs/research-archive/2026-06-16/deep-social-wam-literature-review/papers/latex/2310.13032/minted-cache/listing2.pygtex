\begin{Verbatim}[commandchars=\\\{\},codes={\catcode`\$=3\catcode`\^=7\catcode`\_=8\relax}]
\PYG{k}{def} \PYG{n+nf}{sort\PYGZus{}array}\PYG{p}{(}\PYG{n}{array}\PYG{p}{):}
    \PYG{c+c1}{\PYGZsh{} Create a copy of array}
    \PYG{n}{array\PYGZus{}copy} \PYG{o}{=} \PYG{n}{array}\PYG{p}{[:]}

    \PYG{c+c1}{\PYGZsh{} Determine the length of the array}
    \PYG{n}{n} \PYG{o}{=} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{)}
    
    \PYG{c+c1}{\PYGZsh{} check the sum of first and last elements, is it even or odd}
    \PYG{n}{order} \PYG{o}{=} \PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]} \PYG{o}{+} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{])} \PYG{o}{\PYGZpc{}} \PYG{l+m+mi}{2} \PYG{k}{if} \PYG{n}{n} \PYG{k}{else} \PYG{l+m+mi}{0}

    \PYG{c+c1}{\PYGZsh{} Use insertion sort to sort array}
    \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{n}\PYG{p}{):}
        \PYG{n}{key} \PYG{o}{=} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]}
        \PYG{n}{j} \PYG{o}{=} \PYG{n}{i} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1}
        \PYG{k}{while} \PYG{n}{j} \PYG{o}{\PYGZgt{}=} \PYG{l+m+mi}{0}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} compare array[j] and key according to the \PYGZsq{}order\PYGZsq{}}
            \PYG{n}{condition} \PYG{o}{=} \PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]} \PYG{o}{\PYGZgt{}} \PYG{n}{key}\PYG{p}{)} \PYG{k}{if} \PYG{n}{order} \PYG{k}{else} \PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]} \PYG{o}{\PYGZlt{}} \PYG{n}{key}\PYG{p}{)}
            \PYG{k}{if} \PYG{n}{condition}\PYG{p}{:}
                \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{=} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]}
                \PYG{n}{j} \PYG{o}{\PYGZhy{}=} \PYG{l+m+mi}{1}
            \PYG{k}{else}\PYG{p}{:}
                \PYG{k}{break}
        \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{=} \PYG{n}{key}

    \PYG{k}{return} \PYG{n}{array\PYGZus{}copy}
\end{Verbatim}
