\begin{Verbatim}[commandchars=\\\{\},codes={\catcode`\$=3\catcode`\^=7\catcode`\_=8\relax}]
\PYG{k}{def} \PYG{n+nf}{sort\PYGZus{}array}\PYG{p}{(}\PYG{n}{array}\PYG{p}{):}
    \PYG{c+c1}{\PYGZsh{} Copy the array so as not to modify the original}
    \PYG{n}{array\PYGZus{}copy} \PYG{o}{=} \PYG{n}{array}\PYG{o}{.}\PYG{n}{copy}\PYG{p}{()}
    
    \PYG{c+c1}{\PYGZsh{} If the array is empty or has only one element, return it as is}
    \PYG{k}{if} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{)} \PYG{o+ow}{in} \PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{p}{):}
        \PYG{k}{return} \PYG{n}{array\PYGZus{}copy}

    \PYG{c+c1}{\PYGZsh{} Check the sum condition and sort accordingly}
    \PYG{k}{if} \PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]} \PYG{o}{+} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{])} \PYG{o}{\PYGZpc{}} \PYG{l+m+mi}{2} \PYG{o}{==} \PYG{l+m+mi}{0}\PYG{p}{:}  \PYG{c+c1}{\PYGZsh{} if sum is even}
        \PYG{c+c1}{\PYGZsh{} Use bubble sort in descending order}
        \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{)):}
            \PYG{k}{for} \PYG{n}{j} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{)} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1}\PYG{p}{):}
                \PYG{k}{if} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]} \PYG{o}{\PYGZlt{}} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{]:}
                    \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{],} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{=} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{],} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]}  \PYG{c+c1}{\PYGZsh{} swap}
    \PYG{k}{else}\PYG{p}{:}  \PYG{c+c1}{\PYGZsh{} if sum is odd}
        \PYG{c+c1}{\PYGZsh{} Use bubble sort in ascending order}
        \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{)):}
            \PYG{k}{for} \PYG{n}{j} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array\PYGZus{}copy}\PYG{p}{)} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1}\PYG{p}{):}
                \PYG{k}{if} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]} \PYG{o}{\PYGZgt{}} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{]:}
                    \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{],} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{=} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{],} \PYG{n}{array\PYGZus{}copy}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]}  \PYG{c+c1}{\PYGZsh{} swap}
                    
    \PYG{k}{return} \PYG{n}{array\PYGZus{}copy}
\end{Verbatim}
