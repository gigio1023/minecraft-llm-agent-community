    \PYG{c+c1}{\PYGZsh{} Recursive function to perform the Bubble Sort method}
    \PYG{k}{def} \PYG{n+nf}{bubble\PYGZus{}sort}\PYG{p}{(}\PYG{n}{lst}\PYG{p}{,} \PYG{n}{compare}\PYG{p}{):}
