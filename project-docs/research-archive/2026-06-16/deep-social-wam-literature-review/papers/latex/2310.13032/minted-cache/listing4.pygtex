                    \PYG{n}{lst}\PYG{p}{[}\PYG{n}{i}\PYG{p}{],} \PYG{n}{lst}\PYG{p}{[}\PYG{n}{i} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{=} \PYG{n}{lst}\PYG{p}{[}\PYG{n}{i} \PYG{o}{+} \PYG{l+m+mi}{1}\PYG{p}{],} \PYG{n}{lst}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]}
                    \PYG{n}{swapped} \PYG{o}{=} \PYG{k+kc}{True}
        \PYG{k}{return} \PYG{n}{lst}
    \PYG{c+c1}{\PYGZsh{} Decide the comparison method depending on the sum of the first and last elements of the list}
    \PYG{n}{compare} \PYG{o}{=} \PYG{p}{(}\PYG{k}{lambda} \PYG{n}{x}\PYG{p}{,} \PYG{n}{y}\PYG{p}{:} \PYG{n}{x} \PYG{o}{\PYGZgt{}} \PYG{n}{y}\PYG{p}{)} \PYG{k}{if} \PYG{p}{(}\PYG{n}{array}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]} \PYG{o}{+} \PYG{n}{array}\PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{])} \PYG{o}{\PYGZpc{}} \PYG{l+m+mi}{2} \PYG{k}{else} \PYG{p}{(}\PYG{k}{lambda} \PYG{n}{x}\PYG{p}{,} \PYG{n}{y}\PYG{p}{:} \PYG{n}{x} \PYG{o}{\PYGZlt{}} \PYG{n}{y}\PYG{p}{)}
