\begin{Verbatim}[commandchars=\\\{\},codes={\catcode`\$=3\catcode`\^=7\catcode`\_=8\relax}]
\PYG{k}{def} \PYG{n+nf}{sort\PYGZus{}array}\PYG{p}{(}\PYG{n}{array}\PYG{p}{):}
    \PYG{c+c1}{\PYGZsh{} Base cases: if the list is empty or only has one element, return the list as it is.}
    \PYG{k}{if} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{array}\PYG{p}{)} \PYG{o}{\PYGZlt{}=} \PYG{l+m+mi}{1}\PYG{p}{:}
