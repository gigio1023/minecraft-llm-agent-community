\begin{Verbatim}[commandchars=\\\{\}]
\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{Create a code that}
\PYG{l+s+sd}{summation}
\PYG{l+s+sd}{of all numbers}
\PYG{l+s+sd}{between 1 to n.}
\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{k}{def} \PYG{n+nf}{sum\PYGZus{}all\PYGZus{}nums}\PYG{p}{(}\PYG{n}{n}\PYG{p}{):}
    \PYG{n}{res} \PYG{o}{=} \PYG{l+m+mi}{0}
    \PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{n}\PYG{o}{+}\PYG{l+m+mi}{1}\PYG{p}{):}
        \PYG{n}{res} \PYG{o}{+=} \PYG{n}{i}
    \PYG{k}{return} \PYG{n}{res}

\PYG{n+nb}{print}\PYG{p}{(}\PYG{n}{sum\PYGZus{}all\PYGZus{}nums}\PYG{p}{(}\PYG{n}{n}\PYG{p}{))} \PYG{c+c1}{\PYGZsh{} 15}
\end{Verbatim}
