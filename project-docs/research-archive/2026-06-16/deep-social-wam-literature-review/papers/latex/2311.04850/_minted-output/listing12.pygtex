\begin{Verbatim}[commandchars=\\\{\}]
\PYG{k}{def} \PYG{n+nf}{iscube}\PYG{p}{(}\PYG{n}{a}\PYG{p}{):}
    \PYG{l+s+sd}{\PYGZsq{}\PYGZsq{}\PYGZsq{}}
\PYG{l+s+sd}{    Write a function that takes an}
\PYG{l+s+sd}{    integer a and returns True}
\PYG{l+s+sd}{    if this ingeger is a cube of}
\PYG{l+s+sd}{    some integer number.}
\PYG{l+s+sd}{    Note: you may assume the input}
\PYG{l+s+sd}{    is always valid.}
\PYG{l+s+sd}{    Examples:}
\PYG{l+s+sd}{    iscube(1) ==\PYGZgt{} True}
\PYG{l+s+sd}{    iscube(2) ==\PYGZgt{} False (the}
\PYG{l+s+sd}{    length of each side must}
\PYG{l+s+sd}{    be greater than zero)}
\PYG{l+s+sd}{    iscube(\PYGZhy{}1) ==\PYGZgt{} True}
\PYG{l+s+sd}{    iscube(64) ==\PYGZgt{} True}
\PYG{l+s+sd}{    iscube(0) ==\PYGZgt{} True}
\PYG{l+s+sd}{    iscube(180) ==\PYGZgt{} False}

\PYG{l+s+sd}{    Example solution:}
\PYG{l+s+sd}{    \PYGZsh{} line 1}
\PYG{l+s+sd}{    a = abs(a)}
\PYG{l+s+sd}{    \PYGZsh{} line 2}
\PYG{l+s+sd}{    cube\PYGZus{}root = int(round(a}
\PYG{l+s+sd}{        ** (1. / 3)))}
\PYG{l+s+sd}{    \PYGZsh{} line 3}
\PYG{l+s+sd}{    if cube\PYGZus{}root \PYGZca{} 3 == a:}
\PYG{l+s+sd}{        \PYGZsh{} line 4}
\PYG{l+s+sd}{        return True}
\PYG{l+s+sd}{    \PYGZsh{} line 5}
\PYG{l+s+sd}{    else:}
\PYG{l+s+sd}{        \PYGZsh{} line 6}
\PYG{l+s+sd}{        return False}

\PYG{l+s+sd}{    \PYGZsq{}\PYGZsq{}\PYGZsq{}}
    \PYG{c+c1}{\PYGZsh{} Please print out which line of}
    \PYG{c+c1}{\PYGZsh{} the above program contains an}
    \PYG{c+c1}{\PYGZsh{} error. E.g. if the bug is on}
    \PYG{c+c1}{\PYGZsh{} line 4 then print 4}
    \PYG{c+c1}{\PYGZsh{} END OF CONTEXT}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}3\PYGZdq{}}\PYG{p}{)}
    \PYG{c+c1}{\PYGZsh{} END OF SOLUTION}
\end{Verbatim}
