\begin{Verbatim}[commandchars=\\\{\}]
\PYG{k}{def} \PYG{n+nf}{digitSum}\PYG{p}{(}\PYG{n}{s}\PYG{p}{):}
    \PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Task}
\PYG{l+s+sd}{    Write a function that takes a}
\PYG{l+s+sd}{    string as input and returns}
\PYG{l+s+sd}{    the sum of the upper}
\PYG{l+s+sd}{    characters only\PYGZsq{} ASCII codes.}

\PYG{l+s+sd}{    Examples:}
\PYG{l+s+sd}{        digitSum(\PYGZdq{}\PYGZdq{}) =\PYGZgt{} 0}
\PYG{l+s+sd}{        digitSum(\PYGZdq{}abAB\PYGZdq{}) =\PYGZgt{} 131}
\PYG{l+s+sd}{        digitSum(\PYGZdq{}abcCd\PYGZdq{}) =\PYGZgt{} 67}
\PYG{l+s+sd}{        digitSum(\PYGZdq{}helloE\PYGZdq{}) =\PYGZgt{} 69}
\PYG{l+s+sd}{        digitSum(\PYGZdq{}woArBld\PYGZdq{}) =\PYGZgt{} 131}
\PYG{l+s+sd}{        digitSum(\PYGZdq{}aAaaaXa\PYGZdq{}) =\PYGZgt{} 153}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{k}{if} \PYG{n}{s} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}}\PYG{p}{:} \PYG{k}{return} \PYG{l+m+mi}{0}
    \PYG{k}{return} \PYG{n+nb}{sum}\PYG{p}{(}\PYG{n+nb}{ord}\PYG{p}{(}\PYG{n}{char}\PYG{p}{)}
        \PYG{k}{if} \PYG{n}{char}\PYG{o}{.}\PYG{n}{isupper}\PYG{p}{()} \PYG{k}{else} \PYG{l+m+mi}{0}
        \PYG{k}{for} \PYG{n}{char} \PYG{o+ow}{in} \PYG{n}{s}\PYG{p}{)}
\end{Verbatim}
