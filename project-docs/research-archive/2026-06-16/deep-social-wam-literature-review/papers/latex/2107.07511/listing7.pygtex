\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c+c1}{\PYGZsh{} model is a multi\PYGZhy{}class neural network, X.shape[0]=Y.shape[0]=n}
\PYG{n}{lambdas} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{linspace}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{,}\PYG{l+m+mi}{1}\PYG{p}{,}\PYG{n}{N}\PYG{p}{)} \PYG{c+c1}{\PYGZsh{} N can be taken to infinity without penalty}
\PYG{n}{losses} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{((}\PYG{n}{n}\PYG{p}{,}\PYG{n}{N}\PYG{p}{))} \PYG{c+c1}{\PYGZsh{} loss for example i with parameter lambdas[j]}
\PYG{k}{for} \PYG{n}{i} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{n}\PYG{p}{):} \PYG{c+c1}{\PYGZsh{} In reality we parallelize these loops massively}
  \PYG{n}{sigmoids} \PYG{o}{=} \PYG{n}{model}\PYG{p}{(}\PYG{n}{X}\PYG{p}{[}\PYG{n}{i}\PYG{p}{]}\PYG{o}{.}\PYG{n}{unsqueeze}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{))}\PYG{o}{.}\PYG{n}{sigmoid}\PYG{p}{()}\PYG{o}{.}\PYG{n}{squeeze}\PYG{p}{()} \PYG{c+c1}{\PYGZsh{} Care with dims}
  \PYG{k}{for} \PYG{n}{j} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{N}\PYG{p}{):}
    \PYG{n}{T} \PYG{o}{=} \PYG{n}{sigmoids} \PYG{o}{\PYGZgt{}} \PYG{n}{lambdas}\PYG{p}{[}\PYG{n}{j}\PYG{p}{]} \PYG{c+c1}{\PYGZsh{} This is the prediction set}
    \PYG{n}{set\PYGZus{}size} \PYG{o}{=} \PYG{n}{T}\PYG{o}{.}\PYG{n}{float}\PYG{p}{()}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{()}
    \PYG{k}{if} \PYG{n}{set\PYGZus{}size} \PYG{o}{!=} \PYG{l+m+mi}{0}\PYG{p}{:}
      \PYG{n}{losses}\PYG{p}{[}\PYG{n}{i}\PYG{p}{,}\PYG{n}{j}\PYG{p}{]} \PYG{o}{=} \PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{p}{(}\PYG{n}{T}\PYG{p}{[}\PYG{n}{Y}\PYG{p}{]} \PYG{o}{==} \PYG{k+kc}{True}\PYG{p}{)}\PYG{o}{.}\PYG{n}{float}\PYG{p}{()}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{()}\PYG{o}{/}\PYG{n}{set\PYGZus{}size}
\PYG{n}{risk} \PYG{o}{=} \PYG{n}{losses}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{n}{dim}\PYG{o}{=}\PYG{l+m+mi}{0}\PYG{p}{)}
\PYG{n}{pvals} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{exp}\PYG{p}{(}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{2}\PYG{o}{*}\PYG{n}{n}\PYG{o}{*}\PYG{p}{(}\PYG{n}{torch}\PYG{o}{.}\PYG{n}{relu}\PYG{p}{(}\PYG{n}{alpha}\PYG{o}{\PYGZhy{}}\PYG{n}{risk}\PYG{p}{)}\PYG{o}{**}\PYG{l+m+mi}{2}\PYG{p}{))} \PYG{c+c1}{\PYGZsh{} Or the HB p\PYGZhy{}value}
\PYG{c+c1}{\PYGZsh{} Fixed\PYGZhy{}sequence test starting at lambdas[\PYGZhy{}1] and ending at lambdas[0]}
\PYG{n}{below\PYGZus{}delta} \PYG{o}{=} \PYG{p}{(}\PYG{n}{pvals} \PYG{o}{\PYGZlt{}=} \PYG{n}{delta}\PYG{p}{)}\PYG{o}{.}\PYG{n}{float}\PYG{p}{()}
\PYG{n}{valid} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{tensor}\PYG{p}{([(}\PYG{n}{below\PYGZus{}delta}\PYG{p}{[}\PYG{n}{j}\PYG{p}{:]}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{()} \PYG{o}{==} \PYG{l+m+mi}{1}\PYG{p}{)} \PYG{k}{for} \PYG{n}{j} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{N}\PYG{p}{)])}
\PYG{n}{lambda\PYGZus{}hat} \PYG{o}{=} \PYG{n}{lambdas}\PYG{p}{[}\PYG{n}{valid}\PYG{p}{]}
\end{Verbatim}
