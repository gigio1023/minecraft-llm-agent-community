\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c+c1}{\PYGZsh{} Q: There were nine computers in the server room. Five more computers were installed each day, from monday to thursday. How many computers are now in the server room?}
\PYG{c+c1}{\PYGZsh{} solution using Python:}

\PYG{k}{def} \PYG{n+nf}{solution}\PYG{p}{():}
    \PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}There were nine computers in the server room. Five more computers were installed each day, from monday to thursday. How many computers are now in the server room?\PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{computers\PYGZus{}initial} \PYG{o}{=} \PYG{l+m+mi}{9}
    \PYG{n}{computers\PYGZus{}per\PYGZus{}day} \PYG{o}{=} \PYG{l+m+mi}{5}
    \PYG{n}{num\PYGZus{}days} \PYG{o}{=} \PYG{l+m+mi}{4}  \PYG{c+c1}{\PYGZsh{} 4 days between monday and thursday}
    \PYG{n}{computers\PYGZus{}added} \PYG{o}{=} \PYG{n}{computers\PYGZus{}per\PYGZus{}day} \PYG{o}{*} \PYG{n}{num\PYGZus{}days}
    \PYG{n}{computers\PYGZus{}total} \PYG{o}{=} \PYG{n}{computers\PYGZus{}initial} \PYG{o}{+} \PYG{n}{computers\PYGZus{}added}
    \PYG{n}{result} \PYG{o}{=} \PYG{n}{computers\PYGZus{}total}
    \PYG{k}{return} \PYG{n}{result}
\end{Verbatim}
