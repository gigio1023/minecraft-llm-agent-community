\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c+c1}{\PYGZsh{} Let\PYGZsq{}s go through the error and check step\PYGZhy{}by\PYGZhy{}step}
\PYG{n}{plates} \PYG{o}{=} \PYG{l+m+mi}{6}
\PYG{n}{plate\PYGZus{}cost} \PYG{o}{=} \PYG{l+m+mi}{6000}

\PYG{c+c1}{\PYGZsh{} Let\PYGZsq{}s check the other parts}
