\PYG{n}{cup\PYGZus{}cost} \PYG{o}{=} \PYG{n}{plate\PYGZus{}cost}  \PYG{c+c1}{\PYGZsh{} wrong! The cost of a cup is not the same as the cost of a plate.}
\PYG{c+c1}{\PYGZsh{} The cost of a cup is \PYGZdl{}1200 less than the total cost of half a dozen plates sold at \PYGZdl{}6000 each.}
\PYG{n}{half\PYGZus{}dozen\PYGZus{}plate\PYGZus{}cost} \PYG{o}{=} \PYG{l+m+mi}{6} \PYG{o}{*} \PYG{n}{plate\PYGZus{}cost}
\PYG{n}{cup\PYGZus{}cost} \PYG{o}{=} \PYG{n}{half\PYGZus{}dozen\PYGZus{}plate\PYGZus{}cost} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1200}
